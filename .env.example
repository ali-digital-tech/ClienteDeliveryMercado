# Copie este arquivo para .env (desenvolvimento) ou configure as mesmas variáveis
# no provedor de hospedagem antes de gerar o build. Reinicie o Vite após alterá-lo.
#
# ATENÇÃO: variáveis VITE_* são incorporadas ao JavaScript enviado ao navegador.
# Nunca informe senhas, chaves privadas, service_role do Supabase ou credenciais
# administrativas neste arquivo.

# URL pública do backend, incluindo o sufixo /api e sem barra no final.
# Onde obter: URL pública do serviço backend-node-with-AI no provedor em que ele
# está publicado (por exemplo, Cloud Run, Railway ou Render). Em desenvolvimento,
# use a URL do backend local, como http://localhost:3000/api.
VITE_API_BASE_URL=https://seu-backend.exemplo.com/api

# URL pública deste aplicativo do cliente, sem barra no final. É usada nos links
# de redefinição de senha enviados por e-mail.
# Onde obter: domínio configurado para este app no provedor de hospedagem. Para
# desenvolvimento local, use a URL exibida por `npm run dev` (normalmente
# http://localhost:5173).
VITE_APP_BASE_URL=https://cliente.seudominio.com

# Configuração do aplicativo Web no Firebase, usada para autenticação, Analytics
# e notificações push. Onde obter cada valor: Firebase Console > Configurações do
# projeto > Geral > Seus apps > aplicativo Web > Configuração do SDK.
VITE_FIREBASE_API_KEY=cole_a_api_key_do_firebase
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-project-id
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Identificador do Google Analytics do mesmo aplicativo Firebase.
# Onde obter: Firebase Console > Configurações do projeto > Geral > Seus apps >
# aplicativo Web > Configuração do SDK. Se o Analytics não estiver habilitado,
# deixe vazio.
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Chave pública VAPID para notificações web via Firebase Cloud Messaging (FCM).
# Onde obter: Firebase Console > Configurações do projeto > Cloud Messaging >
# Configuração da Web > Certificados Web Push.
VITE_FIREBASE_VAPID_KEY=cole_a_chave_publica_vapid

# Credenciais públicas para o Realtime do salão/QR. Onde obter: Supabase Dashboard
# > projeto usado pelo backend > Project Settings > API > Project URL e Publishable
# key (ou a chave anon legada). Não use a chave service_role neste frontend.
VITE_SUPABASE_URL=https://seu-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=cole_a_chave_publishable_ou_anon_do_supabase

# Versão exibida no rodapé do perfil.
# Onde obter: versão da release do cliente, normalmente a versão definida em
# package.json ou a tag/versionamento adotado no seu processo de deploy.
VITE_APP_VERSION=1.0.0
